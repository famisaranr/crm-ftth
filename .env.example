# =============================================================
# FiberOps PH - Environment Configuration
# Copy to .env and fill in values
# =============================================================

# ── Database ──────────────────────────────────────────────────
POSTGRES_DB=fiberops
POSTGRES_USER=fiberops
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://fiberops:CHANGE_ME@postgres:5432/fiberops

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── JWT Secrets ───────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET_MIN_32_CHARS

# ── API Server ────────────────────────────────────────────────
API_PORT=3001
ALLOWED_ORIGINS=http://localhost:3000,https://fiberops.example.com
APP_VERSION=1.0.0

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ── Mail (Optional) ──────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@fiberops.example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=FiberOps PH <noreply@fiberops.example.com>
